<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <!-- Toolbar / Nav -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/color_background"
        android:elevation="1dp" />

    <!-- Hero -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/color_surface"
        android:padding="@dimen/spacing_16"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kotlin Android Fixture"
            android:textAppearance="@style/TextAppearance.FixtureApp.Heading" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_4"
            android:text="Design system test fixture for the design-extractor skill."
            android:textAppearance="@style/TextAppearance.FixtureApp.Body" />

        <include layout="@layout/component_button" android:layout_marginTop="@dimen/spacing_6" />
    </LinearLayout>

    <!-- Cards -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_4">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:dividerPadding="@dimen/spacing_4">

            <include layout="@layout/component_card" android:layout_marginBottom="@dimen/spacing_4" />
            <include layout="@layout/component_card" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
